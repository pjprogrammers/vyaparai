rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: only the business owner can access their data.
    function isOwner(businessId) {
      return request.auth != null
        && request.auth.uid == businessId.replace('biz_', '');
    }

    // Users — a user can only read/write their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Businesses — only the owner can read/write.
    match /businesses/{businessId} {
      allow read, write: if isOwner(businessId);
    }

    // Products — scoped to business owner.
    match /products/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Suppliers — scoped to business owner.
    match /suppliers/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Invoices — scoped to business owner.
    match /invoices/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Sales — scoped to business owner.
    match /sales/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Expenses — scoped to business owner.
    match /expenses/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // AI Insights — scoped to business owner.
    match /aiInsights/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Customer messages — scoped to business owner.
    match /customerMessages/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Generated invoices — scoped to business owner.
    match /generatedInvoices/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Customers — scoped to business owner.
    match /customers/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Inventory logs — scoped to business owner.
    match /inventoryLogs/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Notifications — scoped to business owner.
    match /notifications/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Reports — scoped to business owner.
    match /reports/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Settings — scoped to business owner.
    match /settings/{document=**} {
      allow read, write: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
    }

    // Audit logs — read only for owner, system writes only.
    match /auditLogs/{document=**} {
      allow read: if request.auth != null
        && resource.data.businessId == 'biz_' + request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
