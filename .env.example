# ============================================================================
# VyaparAI — Environment Configuration
# This file IS committed to GitHub (no real secrets inside).
# For local dev, copy it to `.env.local` and fill in real values.
#
# On Vercel, add these same variables in Project → Settings → Environment
# Variables. Toggle "Sensitive" ON for every variable marked [SENSITIVE]
# below. NEXT_PUBLIC_* variables are embedded in the browser bundle, so they
# must stay [NOT SENSITIVE] — Vercel will warn if you mark them sensitive.
# ============================================================================

# ----------------------------------------------------------------------------
# Site URL  [NOT SENSITIVE — used for canonical URLs, sitemap, OG, schema]
# Set this to your production domain (no trailing slash). Drives all absolute
# SEO URLs. On Vercel: leave "Sensitive" OFF.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://vyaparai.vercel.app

# ----------------------------------------------------------------------------
# Firebase Web SDK  [NOT SENSITIVE — exposed to the browser via NEXT_PUBLIC_]
# Found in Firebase Console → Project settings → Your apps → SDK config.
# On Vercel: leave "Sensitive" OFF.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----------------------------------------------------------------------------
# Gemini API key  [SENSITIVE — server only, never sent to browser]
# Google AI Studio: https://aistudio.google.com/apikey
# On Vercel: toggle "Sensitive" ON.
# ----------------------------------------------------------------------------
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Firebase Admin SDK  [SENSITIVE — server only]
# Used by server-side code (seed script, dashboard aggregation, server writes).
# Generate a service-account key in Firebase Console → Project settings →
# Service accounts → Generate new private key. The JSON gives you client_email
# and private_key. Paste the private key WITH the surrounding quotes; escape
# newlines as \n (or keep literal newlines in Vercel's UI).
# On Vercel: toggle "Sensitive" ON for BOTH of these.
# ----------------------------------------------------------------------------
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# OCR provider  [NOT SENSITIVE — just a toggle]
# "tesseract" (free, default, runs server-side) or "vision" (Google Cloud Vision).
# On Vercel: leave "Sensitive" OFF.
# ----------------------------------------------------------------------------
OCR_PROVIDER=tesseract

# Only needed if OCR_PROVIDER=vision  [SENSITIVE]
# GOOGLE_CLOUD_VISION_API_KEY=
